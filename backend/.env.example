# Environment contract for the BOCC backend.
# Read and validated in one place: netlify/functions/utils/config.js
# Missing any REQUIRED secret makes the functions fail fast at cold start.

# --- REQUIRED secrets -------------------------------------------------------
# Airtable
AIRTABLE_API_KEY=your_airtable_api_key_here
AIRTABLE_BASE_ID=your_base_id_here

# Circle.so — Admin API v2 token
CIRCLE_API_TOKEN=your_circle_admin_token_here
# Circle.so — Headless Auth API token (bot JWT generation)
CIRCLE_HEADLESS_API=your_circle_headless_token_here

# --- OPTIONAL (have defaults; override per environment) ----------------------
# CORS: set to your frontend domain in production (e.g. "https://716coffee.club").
# Defaults to "*" if not set.
ALLOWED_ORIGIN=*

# Supabase Postgres — the post-migration transactional store (ADR 0003).
# OPTIONAL until the check-in cutover; the Supabase path is opt-in. This is the
# TRANSACTION-POOLER connection string for the least-privilege `checkin_writer`
# role (NOT postgres, NOT service_role). Copy the pooler string from the Supabase
# dashboard (Connect → Transaction pooler), swap the user to checkin_writer, and
# URL-ENCODE any special characters in the password. Do NOT include sslmode —
# SSL is governed in code (verify-full via the CA). See SUPABASE_PERMISSIONS.md.
#   postgresql://checkin_writer.<project-ref>:<urlenc-password>@<region>.pooler.supabase.com:6543/postgres
# SUPABASE_CHECKIN_WRITER_URL=
# Pool size per function instance (serverless). Defaults to 1.
# SUPABASE_POOL_MAX=1
# Supabase CA certificate (PEM) for verify-full TLS. Optional: leave unset if you
# pasted the CA into netlify/functions/utils/supabase-ca.js instead. The cert is
# public (download from dashboard → Database → SSL Configuration).
# SUPABASE_CA_CERT=

# Bot / admin / test identities. Defaults match the current 716.social community;
# override only if running against a different Circle community.
# BOT_USER_ID=73e5a590
# BOT_USER_EMAIL=bocc-bot@zackglick.com
# BOT_USER_NAME=716.social Bot
# ADMIN_MEMBER_ID=2d8e9215
# TEST_USER_EMAIL=zglicka@gmail.com

# Shared secret required to trigger the MANUAL enforcement endpoint over HTTP
# (sent as the `x-enforcement-token` request header). If unset, that endpoint
# fails closed and rejects all calls. Not used by the scheduled cron run.
# Generate a long random value, e.g. `openssl rand -hex 32`.
# ENFORCEMENT_TRIGGER_TOKEN=

# NOTE: safety limits (warn at 500, hard-stop at 1000 members) are intentionally
# NOT env-configurable — changing them requires a reviewed code change.
# See docs/backend/SAFETY_LIMITS_SPECIFICATION.md.

# --- Test-only --------------------------------------------------------------
# Token for smoke tests
TEST_TOKEN=test-smoke-token
