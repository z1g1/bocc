# Environment contract for the BOCC backend.
# Read and validated in one place: netlify/functions/utils/config.js
# Missing any REQUIRED secret makes the functions fail fast at cold start.

# --- REQUIRED secrets -------------------------------------------------------
# Airtable
AIRTABLE_API_KEY=your_airtable_api_key_here
AIRTABLE_BASE_ID=your_base_id_here

# Circle.so — Admin API v2 token
CIRCLE_API_TOKEN=your_circle_admin_token_here
# Circle.so — Headless Auth API token (bot JWT generation)
CIRCLE_HEADLESS_API=your_circle_headless_token_here

# --- OPTIONAL (have defaults; override per environment) ----------------------
# CORS: set to your frontend domain in production (e.g. "https://716coffee.club").
# Defaults to "*" if not set.
ALLOWED_ORIGIN=*

# Bot / admin / test identities. Defaults match the current 716.social community;
# override only if running against a different Circle community.
# BOT_USER_ID=73e5a590
# BOT_USER_EMAIL=bocc-bot@zackglick.com
# BOT_USER_NAME=716.social Bot
# ADMIN_MEMBER_ID=2d8e9215
# TEST_USER_EMAIL=zglicka@gmail.com

# NOTE: safety limits (warn at 500, hard-stop at 1000 members) are intentionally
# NOT env-configurable — changing them requires a reviewed code change.
# See docs/backend/SAFETY_LIMITS_SPECIFICATION.md.

# --- Test-only --------------------------------------------------------------
# Token for smoke tests
TEST_TOKEN=test-smoke-token
